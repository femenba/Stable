# Stripe — add these to your .env.local
# Get keys from: https://dashboard.stripe.com/test/apikeys

STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# Create a monthly recurring price at: https://dashboard.stripe.com/test/products
# Product: stable. Pro · Price: £4.99/month · recurring
STRIPE_PRO_MONTHLY_PRICE_ID=price_...

# Public app URL (used in checkout success/cancel redirects)
NEXT_PUBLIC_APP_URL=https://stableadhd.com
# For local dev:
# NEXT_PUBLIC_APP_URL=http://localhost:3001
