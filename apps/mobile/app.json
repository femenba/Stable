{
  "expo": {
    "name": "stable.",
    "slug": "stable",
    "version": "1.0.0",
    "orientation": "portrait",
    "scheme": "stable",
    "userInterfaceStyle": "automatic",
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.stable.app",
      "infoPlist": {
        "NSUserNotificationsUsageDescription": "stable. uses notifications to remind you at the time you set.",
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "package": "com.stable.app",
      "adaptiveIcon": {
        "backgroundColor": "#4f3aff"
      },
      "permissions": [
        "RECEIVE_BOOT_COMPLETED",
        "SCHEDULE_EXACT_ALARM"
      ]
    },
    "plugins": [
      "expo-router",
      "expo-secure-store",
      [
        "expo-notifications",
        {
          "color": "#4f3aff"
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "0b313b06-42af-47e1-9a95-aaf9537c25cd"
      }
    }
  }
}
